# Copia in apps/api/.env (e carica Prisma) / esporta in shell secondo la tua abitudine
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/admin_demo?schema=public"

# API (apps/api) — origine frontend per CORS (development default: Vite)
WEB_ORIGIN="http://localhost:5173"

# API — porta server HTTP
PORT=3001

# Frontend (apps/web) — URL pubblico dell’API usato dal browser (build-time per produzione)
VITE_API_URL="http://localhost:3001"
